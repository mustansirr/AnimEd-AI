# Supabase Configuration for Verification Scripts (Local)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# The scripts look for both keys, but SERVICE_ROLE is preferred for admin tasks.
SUPABASE_KEY=your_service_role_key

# Optional: Google Auth (for local Supabase Auth verification if needed)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your_google_client_id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your_google_client_secret

# LLM Provider Configuration
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Per-node overrides (optional, see backend/.env.example for full docs)
# CODER_LLM_PROVIDER=openrouter
# CODER_LLM_MODEL=qwen/qwen3-coder:free
