# Supabase Configuration
# Make sure to use the Service Role Key for backend operations (bypasses RLS)
SUPABASE_URL=http://127.0.0.1:54321/
SUPABASE_KEY=your_service_role_key

# LLM Provider Configuration — Global Defaults
# These apply to all agent nodes unless overridden below.
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
LLM_PROVIDER=groq            # "groq" or "openrouter"
LLM_MODEL=llama-3.3-70b-versatile

# Per-node LLM Overrides (optional)
# Uncomment to override a specific agent's provider/model.
# If not set, the global LLM_PROVIDER and LLM_MODEL are used.
#
# PLANNER_LLM_PROVIDER=groq
# PLANNER_LLM_MODEL=llama-3.3-70b-versatile
#
# SCRIPTER_LLM_PROVIDER=groq
# SCRIPTER_LLM_MODEL=llama-3.3-70b-versatile
#
# CODER_LLM_PROVIDER=openrouter
# CODER_LLM_MODEL=qwen/qwen3-coder:free
#
# REFLECTOR_LLM_PROVIDER=openrouter
# REFLECTOR_LLM_MODEL=qwen/qwen3-coder:free

# Application Settings
DEBUG=False
